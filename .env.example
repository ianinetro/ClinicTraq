# ── Database ─────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://clinictraq:clinictraq_dev@localhost:5432/clinictraq

# ── Cache / Queue ─────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ── Security ──────────────────────────────────────────────────────────────────
# Generate with: openssl rand -hex 32
SECRET_KEY=change-me-in-production-use-openssl-rand-hex-32
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# PHI field encryption key
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
FERNET_KEY=generate-with-cryptography-fernet-generate-key

# ── App ───────────────────────────────────────────────────────────────────────
ENVIRONMENT=development
DEBUG=true
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# ── Azure Blob Storage (primary file storage) ────────────────────────────────
# Option A: connection string (recommended for Azure App Service)
AZURE_STORAGE_CONNECTION_STRING=
# Option B: account name + key
AZURE_STORAGE_ACCOUNT_NAME=
AZURE_STORAGE_ACCOUNT_KEY=
AZURE_STORAGE_CONTAINER=clinictraq-uploads

# ── Cloudflare R2 (alternative S3-compatible storage) ────────────────────────
# Use R2 instead of Azure Blob if preferred (set R2_ACCOUNT_ID to activate)
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=clinictraq-uploads

# ── Azure Database (production) ───────────────────────────────────────────────
# Azure Database for PostgreSQL Flexible Server
# DATABASE_URL=postgresql+asyncpg://clinictraq@server:password@server.postgres.database.azure.com:5432/clinictraq?ssl=require

# ── Azure Cache for Redis (production) ───────────────────────────────────────
# Azure Cache for Redis uses SSL on port 6380
# REDIS_URL=rediss://:password@cache.redis.cache.windows.net:6380/0

# ── Frontend (injected at build time by Vite) ─────────────────────────────────
VITE_API_URL=http://localhost:8000/api/v1

# ── Integrations ──────────────────────────────────────────────────────────────
NPI_REGISTRY_URL=https://npiregistry.cms.hhs.gov/api/
CLEARINGHOUSE_URL=
CLEARINGHOUSE_API_KEY=
